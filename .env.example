# Copy to .env and fill in — .env is gitignored, never commit real values.
# Only needed for `tv trade-alert check` (SMS trade alerts). Everything else
# in this project works without any of these.

# Anthropic API key for the standalone confidence check (separate from any
# Claude Code subscription — this is billed per-token via the direct API).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the model used for the confidence check.
# Defaults to claude-opus-4-8. Switch to a cheaper model (e.g. claude-sonnet-5,
# claude-haiku-4-5) if you're running this often and want to cut cost.
# ANTHROPIC_ALERT_MODEL=claude-opus-4-8
# ANTHROPIC_ALERT_EFFORT=medium

# Twilio — https://console.twilio.com (Account SID + Auth Token on the console
# dashboard; TWILIO_FROM_NUMBER is a Twilio phone number you own/rent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Your phone number to receive alerts (E.164 format, e.g. +15551234567).
# On a Twilio trial account this number must be verified in the console first.
ALERT_TO_NUMBER=

# Minimum confidence (0-100) before a text is sent. Default 85.
# ALERT_CONFIDENCE_THRESHOLD=85

# Minimum minutes between texts for the same symbol+direction. Default 120.
# ALERT_COOLDOWN_MINUTES=120
