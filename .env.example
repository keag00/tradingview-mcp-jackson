# Copy to .env and fill in — .env is gitignored, never commit real values.
# Only needed for `tv trade-alert check` and `tv orb-alert check` (Pushover
# trade alerts). Everything else in this project works without any of these.

# Anthropic API key for the standalone confidence check (separate from any
# Claude Code subscription — this is billed per-token via the direct API).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the model used for the confidence check.
# Defaults to claude-opus-4-8. Switch to a cheaper model (e.g. claude-sonnet-5,
# claude-haiku-4-5) if you're running this often and want to cut cost.
# ANTHROPIC_ALERT_MODEL=claude-opus-4-8
# ANTHROPIC_ALERT_EFFORT=medium

# Pushover — https://pushover.net (sign up, install the Pushover app on your
# phone — one-time ~$5 purchase per platform after the free trial — then grab
# your User Key from the dashboard and create an Application to get an API
# Token). No compliance registration needed, unlike SMS/Twilio.
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Minimum confidence (0-100) before a text is sent. Default 85.
# ALERT_CONFIDENCE_THRESHOLD=85

# Minimum minutes between texts for the same symbol+direction. Default 120.
# ALERT_COOLDOWN_MINUTES=120

# `tv orb-alert check` only — comma-separated symbol list to watch for real
# ORB EMA Trend [Keagan] entries (no LLM call, the strategy's own entry
# logic is the signal). Default COMEX:GC1! (the best backtested market so
# far — see ORB_STRATEGY_SPEC.md). Add more markets as you find promising
# ones, e.g. "COMEX:GC1!,CME_MINI:NQ1!,NYMEX:NG1!".
# ORB_ALERT_SYMBOLS=COMEX:GC1!

# Minimum minutes between alerts for the same symbol+direction. Default 15 —
# much shorter than ALERT_COOLDOWN_MINUTES above since this only fires on
# genuine new order fills, not a repeatable confidence score.
# ORB_ALERT_COOLDOWN_MINUTES=15

# `tv prop-scalper-alert check` only — same mechanism as ORB_ALERT_SYMBOLS
# above, but for the "Prop Firm Scalper [Keagan]" strategy. Default is
# CME_MINI:ES1!,CME_MINI:NQ1! — the only two markets that strategy has an
# actual verified backtested edge on so far (see PROP_SCALPER_SPEC.md).
# PROP_SCALPER_ALERT_SYMBOLS=CME_MINI:ES1!,CME_MINI:NQ1!
# PROP_SCALPER_ALERT_COOLDOWN_MINUTES=15
